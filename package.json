{
	"name": "react-islands-runtime",
	"license": "MIT",
	"version": "0.3.7",
	"type": "module",
	"description": "SSR-first React islands runtime and server helpers",
	"main": "dist/server/index.js",
	"types": "./types/ssr/index.d.ts",
	"sideEffects": false,
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"src/server/render/**",
		"src/server/router/**",
		"src/server/islands/**",
		"src/server/security/**",
		"src/server/css/**",
		"src/server/theme/**",
		"src/server/manifest.js",
		"src/server/renderRequest.js",
		"src/server/genManifest.js",
		"src/server/serialize.js",
		"src/client/islands-runtime.js",
		"src/shared/serialize.js",
		"dist/server/*.js",
		"dist/client/*.js",
		"dist",
		"packages/ssr/index.js",
		"packages/islands/index.js",
		"packages/rsc/index.js",
		"types/**"
	],
	"exports": {
		".": {
			"types": "./types/ssr/index.d.ts",
			"default": "./dist/server/index.js"
		},
		"./server": {
			"types": "./types/ssr/index.d.ts",
			"default": "./dist/server/index.js"
		},
		"./client/runtime": {
			"types": "./types/islands/index.d.ts",
			"default": "./dist/client/islands-runtime.js"
		},
		"./ssr": {
			"types": "./types/ssr/index.d.ts",
			"default": "./packages/ssr/index.js"
		},
		"./islands": {
			"types": "./types/islands/index.d.ts",
			"default": "./packages/islands/index.js"
		},
		"./rsc": {
			"types": "./types/rsc/index.d.ts",
			"default": "./packages/rsc/index.js"
		}
	},
	"bin": {
		"react-islands-gen-manifest": "src/server/genManifest.js"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"scripts": {
		"pack:patch": "mkdir -p builds && npm version patch --no-git-tag-version && node -e \"const v=require('./package.json').version;require('child_process').execSync('yarn pack --filename builds/react-islands-runtime-'+v+'.tgz',{stdio:'inherit'})\"",
		"pack:minor": "mkdir -p builds && npm version minor --no-git-tag-version && node -e \"const v=require('./package.json').version;require('child_process').execSync('yarn pack --filename builds/react-islands-runtime-'+v+'.tgz',{stdio:'inherit'})\"",
		"pack:major": "mkdir -p builds && npm version major --no-git-tag-version && node -e \"const v=require('./package.json').version;require('child_process').execSync('yarn pack --filename builds/react-islands-runtime-'+v+'.tgz',{stdio:'inherit'})\"",
		"pack:components": "node -e \"const fs=require('fs'),p=require('path'),rv=require('./package.json').version,cp=p.resolve('packages/react-islands-ui/package.json'),pkg=JSON.parse(fs.readFileSync(cp,'utf8'));pkg.version=rv;fs.writeFileSync(cp,JSON.stringify(pkg,null,'\t')+'\\n');const out=p.resolve('builds','react-islands-ui-'+rv+'.tgz');require('child_process').execSync('yarn --cwd packages/react-islands-ui pack --filename '+out,{stdio:'inherit'})\"",
		"pack:all": "npm run pack:patch && npm run pack:components",
		"lint": "yarn lint:js && yarn lint:css",
		"lint:js": "eslint .",
		"lint:css": "stylelint \"**/*.{css,scss,sass,less}\" --allow-empty-input",
		"lint:fix": "eslint . --fix && stylelint \"**/*.{css,scss,sass,less}\" --fix --allow-empty-input",
		"format:fix": "prettier --write .",
		"typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
	},
	"dependencies": {
		"path-to-regexp": "^6.2.2",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@vitejs/plugin-react": "^4.3.4",
		"cross-env": "^10.1.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.17.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"glob": "^13.0.2",
		"globals": "^17.3.0",
		"nodemon": "^3.1.0",
		"prettier": "^3.8.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"stylelint": "^17.2.0",
		"stylelint-config-standard": "^40.0.0",
		"typescript": "^5.8.2",
		"vite": "^6.1.0"
	}
}
