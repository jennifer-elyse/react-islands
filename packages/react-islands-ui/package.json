{
	"name": "react-islands-ui",
	"license": "MIT",
	"version": "0.3.7",
	"type": "module",
	"description": "Island UI components for react-islands-runtime: Carousel, Cart, ProductSearch, and more",
	"sideEffects": false,
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"src/islands/**",
		"src/client/**",
		"index.js",
		"carousel.js"
	],
	"exports": {
