		"./carousel": "./carousel.js",
		"./islands/*": "./src/islands/*",
		"./client/*": "./src/client/*"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0",
		"react-islands-runtime": ">=0.3.0"
	}
}
